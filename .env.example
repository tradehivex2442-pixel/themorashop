# App
APP_NAME="Themora Shop"
APP_URL=http://localhost/themora_Shop/public
APP_ENV=development
APP_DEBUG=true
APP_KEY=your-32-char-secret-key-here

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=themora_shop
DB_USER=root
DB_PASS=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASS=

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=your-app-password
MAIL_FROM_NAME="Themora Shop"
MAIL_FROM_ADDR=noreply@themorashop.com

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# AWS S3 (optional)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_BUCKET=
AWS_REGION=ap-south-1

# AI
OPENAI_API_KEY=

# Push Notifications
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Analytics
GA4_MEASUREMENT_ID=
META_PIXEL_ID=

# Integrations
MAILCHIMP_API_KEY=
MAILCHIMP_LIST_ID=
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
