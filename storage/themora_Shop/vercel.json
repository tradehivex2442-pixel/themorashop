{
  "version": 2,
  "name": "themora-frontend",
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "public/assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
