{
  "version": 2,
  "name": "themora-shop",
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.1" },
    "public/*.php": { "runtime": "vercel-php@0.7.1" }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/test_db.php", "dest": "/public/test_db.php" },
    { "src": "/(.*)", "dest": "/public/index.php" }
  ]
}
