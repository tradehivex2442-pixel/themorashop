{
  "version": 2,
  "name": "themora-shop",
  "functions": {
    "public/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/test_db.php",
      "dest": "/public/test_db.php"
    },
    {
      "src": "/verify.php",
      "dest": "/public/verify.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
